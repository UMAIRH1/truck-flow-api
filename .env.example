PORT=5000
MONGODB_URI=mongodb://localhost:27017/truckflow
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_access_token_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRE=30d

# Cloudinary Configuration (for POD image uploads)
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# SMTP Configuration (not used in MVP, but kept for future)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL=your_email
SMTP_PASSWORD=your_password
FROM_NAME=TruckFlow
FROM_EMAIL=noreply@truckflow.com
